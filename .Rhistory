hsb <- read.csv("https://raw.githubusercontent.com/zief0002/comparing-groups/master/data/HSB.csv")
head(hsb)
#according to codebook, 0 = private, 1 = public
sci_public <- hsb$Sci[hsb$Schtyp == 1]
sci_private <- hsb$Sci[hsb$Schtyp == 0]
diff_schtyp <- var(sci_public) - var(sci_private)
#Boostrap
set.seed(1)
k <- 10000
boot_diffs <- numeric(k)
for(i in 1:k){
boot_public <- sample(sci_public, replace = TRUE)
boot_private <- sample(sci_private, replace = TRUE)
boot_diffs[i] <- var(boot_public) - var(boot_private)
}
p_value_schtyp <- sum(abs(boot_diffs) >= abs(diff_schtyp)) / k
p_value_schtyp
set.seed(1)
# sample sizes
n_pub <- length(sci_public)
n_priv <- length(sci_private)
# pooled variance under H0
var_equal <- var(c(sci_public, sci_private))
# group means
mean_pub <- mean(sci_public)
mean_priv <- mean(sci_private)
# number of bootstrap simulations
k <- 10000
boot_var_diff <- numeric(k)
for(i in 1:k){
sim_pub <- rnorm(n_pub, mean = mean_pub, sd = sqrt(var_equal))
sim_priv <- rnorm(n_priv, mean = mean_priv, sd = sqrt(var_equal))
boot_var_diff[i] <- var(sim_pub) - var(sim_priv)
}
# empirical p-value
p_value_param <- sum(abs(boot_var_diff) >= abs(diff_schtyp)) / k
p_value_param
set.seed(1)
# observed statistic
sample_mean_light <- mean(light)
light <- c(28, 26, 33, 24, 34,-44, 27, 16, 40, -2, 29, 22, 24, 21, 25, 30, 23, 29, 31, 19,
24, 20, 36, 32, 36, 28, 25, 21, 28, 29, 37, 25, 28, 26, 30, 32, 36, 26, 30, 22,
36, 23, 27, 27, 28, 27, 31, 27, 26, 33, 26, 32, 32, 24, 39, 28, 24, 25, 32, 25,
29, 27, 28, 29, 16, 23)
set.seed(1)
# observed statistic
sample_mean_light <- mean(light)
# shift data so mean = 33 under H0
light_null_population <- light + (33 - sample_mean_light)
# bootstrap settings
num_bootstrap <- 100000
bootstrap_means <- numeric(num_bootstrap)
for(i in 1:num_bootstrap){
bootstrap_sample <- sample(light_null_population,
size = length(light_null_population),
replace = TRUE)
bootstrap_means[i] <- mean(bootstrap_sample)
}
# empirical p-value
p_value_light <- sum(abs(bootstrap_means - 33) >=
abs(sample_mean_light - 33)) / num_bootstrap
p_value_light
# remove outliers
light_no_outliers <- light[light != -44 & light != -2]
# new observed mean
sample_mean_no_outliers <- mean(light_no_outliers)
# shift sample so mean = 33 under H0
light_null_population_no_outliers <-
light_no_outliers + (33 - sample_mean_no_outliers)
num_bootstrap <- 100000
bootstrap_means_no_outliers <- numeric(num_bootstrap)
for(i in 1:num_bootstrap){
bootstrap_sample_no_outliers <-
sample(light_null_population_no_outliers,
size = length(light_null_population_no_outliers),
replace = TRUE)
bootstrap_means_no_outliers[i] <- mean(bootstrap_sample_no_outliers)
}
# empirical p-value
p_value_no_outliers <-
sum(abs(bootstrap_means_no_outliers - 33) >=
abs(sample_mean_no_outliers - 33)) / num_bootstrap
p_value_no_outliers
