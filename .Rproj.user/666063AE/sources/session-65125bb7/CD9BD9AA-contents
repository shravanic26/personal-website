/* css styles */
/* Project Cards */

/* Industry projects */

.industry-card {
  border: 1px solid #f8dce6;
  border-radius: 14px;
  padding: 28px;
  margin-bottom: 40px;
  background: #fff8fb;
  box-shadow: 0 4px 14px rgba(0,0,0,0.05);
}

/* Academic projects */

.academic-card {
  border: 1px solid #e4e8f7;
  border-radius: 14px;
  padding: 28px;
  margin-bottom: 40px;
  background: #f7f9ff;
  box-shadow: 0 4px 14px rgba(0,0,0,0.05);
}